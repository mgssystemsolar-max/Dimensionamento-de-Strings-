{
  "entities": {
    "HistoryItem": {
      "title": "HistoryItem",
      "description": "A saved calculation result",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who saved this item"
        },
        "date": {
          "type": "string",
          "description": "The date the item was saved"
        },
        "moduleName": {
          "type": "string",
          "description": "The name of the module used"
        },
        "result": {
          "type": "object",
          "description": "The sizing result"
        }
      },
      "required": ["userId", "date", "moduleName", "result"]
    }
  },
  "firestore": {
    "/users/{userId}/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "User's saved calculation history"
    }
  }
}
